# ── Compose ────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=roadworks
COMPOSE_HTTP_TIMEOUT=180

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=roadworks_db

# ── APISIX ─────────────────────────────────────────────────────────────────────
# Minimum 32 characters
APISIX_ADMIN_KEY=your-admin-key-minimum-32-characters
